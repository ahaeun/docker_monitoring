# docker.from_env()가 읽는 환경변수 (docker-dashboard/.env 로 복사해서 사용)
# 아무것도 설정하지 않으면 로컬 Docker 소켓(/var/run/docker.sock)에 자동 접속합니다.
# 원격 Docker 서버에 접속하고 싶을 때만 아래 값을 채우세요.

# 원격 Docker daemon 주소 (예: tcp://192.168.0.10:2375)
# 아래 SSH_* 값을 채우면 이 값 대신 SSH 터널을 사용합니다.
# DOCKER_HOST=

# TLS로 접속할 경우 1로 설정
# DOCKER_TLS_VERIFY=

# TLS 인증서(cert.pem, key.pem, ca.pem)가 있는 디렉토리 경로
# DOCKER_CERT_PATH=

# Docker API 버전 고정이 필요할 경우
# DOCKER_API_VERSION=

# --- SSH 비밀번호 인증으로 원격 Docker 접속 (pem 키 없이 SSH 비번만 있을 때) ---
# 이 값들이 채워지면 SSH로 접속해 원격 `docker system dial-stdio`를 로컬로 터널링합니다.
# 주의: 비밀번호가 .env에 평문으로 저장됩니다. 이 파일은 반드시 .gitignore로 제외하세요.
# SSH_HOST=
# SSH_PORT=22
# SSH_USER=
# SSH_PASSWORD=
